# Meta App credentials
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=           # Any random string ≥16 chars, used for webhook verification handshake
META_GRAPH_API_VERSION=v25.0

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=       # System User token
WHATSAPP_BUSINESS_ACCOUNT_ID=  # Optional but required for programmatic webhook attachment (POST /{WABA_ID}/subscribed_apps).

# Messenger
MESSENGER_PAGE_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
# REQUIRED by `npm run setup:oauth:messenger` only — the FB Login for Business configuration id that
# bundles the scope set the OAuth flow will request. Create one in Meta App Dashboard → Facebook
# Login for Business → Configurations (include pages_show_list, pages_messaging, pages_manage_metadata,
# pages_read_engagement at minimum). The Dashboard "Generate Token" button can also mint a Page token
# but only with whatever scopes the user has already granted to the app — use this OAuth flow when
# you need scopes beyond that. Not consumed by the running agent.
MESSENGER_LOGIN_CONFIG_ID=

# Instagram (Business Login)
# REQUIRED — paste the embed authorize URL from Meta App Dashboard → Instagram → API setup with
# Instagram Business Login → "Authorize this app for Instagram business" section. Includes
# client_id, redirect_uri, scope, response_type, and state — the OAuth script parses client_id,
# state, and redirect_uri out of it. Avoids URL-construction drift across Meta's evolving auth flows.
INSTAGRAM_AUTHORIZE_URL=
# REQUIRED — the Instagram app secret (NOT the same as META_APP_SECRET). Found in the same
# Dashboard section as the embed URL, labeled "Instagram app secret". Used for the short-lived
# and long-lived OAuth token exchanges AND, at RUNTIME, to verify inbound Instagram webhook
# signatures: Meta signs `object: instagram` webhooks with THIS secret, not META_APP_SECRET
# (verified against the live API 2026-05-20). Required for the Instagram channel to receive
# webhooks — if unset while the IG channel is enabled, every inbound IG webhook fails signature
# verification (401) and the app warns at startup. WhatsApp + Messenger sign with META_APP_SECRET.
INSTAGRAM_APP_SECRET=
# Captured by `npm run setup:oauth:instagram` and appended automatically:
# INSTAGRAM_USER_ID=
# INSTAGRAM_ACCESS_TOKEN=

# Chat endpoint (developer-provided)
CHAT_ENDPOINT_URL=

# Identity enrichment (optional; fail-open)
# Developer-provided lookup endpoint. When set, each inbound triggers a POST of
# { channel, channelScopedUserId, channelScopedBusinessId }; a 2xx JSON body with
# any of firstName/lastName/displayName/email/tags/customVariables/unifiedContactId
# enriches the conversation (and is cached in-process). Leave UNSET to disable —
# the agent then runs a no-op resolver. Enrichment is best-effort: any failure
# (non-2xx, network, timeout, malformed body) is swallowed and the turn proceeds
# WITHOUT enrichment, so a flaky lookup endpoint never blocks message delivery.
USER_LOOKUP_URL=                       # Optional; must be a parseable URL when set
USER_LOOKUP_TIMEOUT_MS=5000            # Timeout for the USER_LOOKUP_URL call (positive int)

# Tunneling (required for setup + capture + dev workflow)
# REQUIRED — reserve a free static ngrok domain at https://dashboard.ngrok.com/cloud-edge/domains.
# Bare hostname only (no https:// scheme). Pinning a static domain avoids re-registering
# the webhook callback URL across three Meta Dashboard configurations every run.
NGROK_DOMAIN=
NGROK_AUTHTOKEN=

# Optional
REDIS_URL=                   # Optional; when set must be a redis:// or rediss:// URL (enables Stage 10 persistence)
ADMIN_API_TOKEN=
PUBLIC_BASE_URL=             # For webhook registration; typically ngrok URL
AGENT_AUTOSTART=1            # Set to 0 to prevent autostart on import
PORT=3000

# Persistence (Redis/BullMQ — production durability; only used when REDIS_URL is set)
CONVERSATION_TTL_SECONDS=86400         # TTL for Redis conversation records + outbound-handle maps (positive int; 1 day)
BUFFER_QUEUE_NAME=meta-ai-buffer-timers  # BullMQ queue name for the buffer-flush scheduler (non-empty string)
BUFFER_WORKER_CONCURRENCY=10           # BullMQ worker concurrency for flush jobs (positive int). >1 so a slow chat call for one conversation doesn't block others.
READY_REDIS_TIMEOUT_MS=2000            # Timeout for the GET /ready Redis ping (positive int)

# Rate limiting + retry (Stage 10)
WHATSAPP_RATE_LIMIT_PER_SECOND=80      # Outbound WhatsApp pacing (msgs/sec; >= 0, 0 disables pacing)
MESSENGER_RATE_LIMIT_PER_SECOND=40     # Outbound Messenger pacing (msgs/sec; >= 0, 0 disables pacing)
INSTAGRAM_RATE_LIMIT_PER_SECOND=10     # Outbound Instagram pacing (msgs/sec; >= 0, 0 disables pacing). 10 = IG media cap + the client's in-process floor; 2/s is the general Graph baseline, not the messaging limit.
TRANSIENT_RETRY_MAX_ATTEMPTS=3         # Max transient-retry attempts after the first send (positive int)
TRANSIENT_RETRY_BASE_MS=1000           # Base backoff for transient retry (positive int; must be <= max)
TRANSIENT_RETRY_MAX_MS=60000           # Max backoff for transient retry (positive int; must be >= base)

# Conversation / buffering / delivery (all optional; defaults shown)
BUFFER_BASE_TIMEOUT_MS=2000            # First-inbound buffer flush delay (positive int)
BUFFER_GROWTH_FACTOR=1.25              # Timeout multiplier per rapid follow-up (float >= 1)
BUFFER_MAX_TIMEOUT_MS=8000             # Ceiling for the buffer flush delay (int; must be >= base)
BUFFER_NOISE_MAX_DEVIATION=0.3         # Max fractional jitter on the flush delay (0..1)
OUTBOUND_TYPING_INDICATORS_ENABLED=true  # Emit typing indicators before sending (1/0/true/false)
TYPING_REFRESH_INTERVAL_MS=5000        # How often a long-lived typing indicator refreshes (positive int)
TYPING_REFRESH_MAX_MS=120000           # Absolute cap on typing refresh per turn (positive int)
READ_RECEIPTS_ENABLED=false            # Mark inbound messages read (best-effort; 1/0/true/false)
OUTBOUND_DELIVERY_TIMEOUT_MS=30000     # Wait for a delivery/send confirmation before advancing (positive int)
CHAT_ENDPOINT_TIMEOUT_MS=30000         # Timeout for the HTTP call to CHAT_ENDPOINT_URL (positive int)
DEDUPE_TTL_SECONDS=86400               # TTL for the inbound dedupe key in the store (positive int)

# Inbound media hydration (opt-in). When INBOUND_MEDIA_DOWNLOAD=true the transport
# downloads inbound media (it holds the WhatsApp access token the chat endpoint
# does not) and attaches it to the chat request as a base64 data URL, so the
# endpoint can SEE WhatsApp images — which arrive as a bare media id, not a
# fetchable URL. OFF by default: base64 inflates each media-bearing request body
# by ~33% over the raw bytes. INBOUND_MEDIA_MAX_BYTES caps a single attachment;
# anything larger is left as id/url and skipped (logged), not base64-attached.
INBOUND_MEDIA_DOWNLOAD=false           # Download + base64-attach inbound media to the chat request (1/0/true/false)
INBOUND_MEDIA_MAX_BYTES=5242880        # Max bytes of a single inbound attachment to hydrate (positive int; 5 MiB)

# E2E
E2E_TEST_WHATSAPP_NUMBER=   # Personal WhatsApp number (E.164)
E2E_TEST_FACEBOOK_PSID=     # Founder's PSID for Messenger testing
E2E_TEST_INSTAGRAM_IGSID=   # Founder's IGSID for Instagram testing
