# Showcase bot environment.
# Copy to .env (this directory) and fill in — `dotenv` is loaded on startup.
# This file is the showcase bot's own config, separate from the root
# meta-ai-agent .env.

# Required for the default Anthropic model: your Anthropic API key.
# https://console.anthropic.com/ — the bot fails fast at startup if the key for
# the SELECTED provider is unset.
ANTHROPIC_API_KEY=

# Optional: OpenAI key — only needed if you switch the model to an openai: id
# (e.g. SHOWCASE_MODEL=openai:gpt-4o-mini).
OPENAI_API_KEY=

# Optional: Groq key — enables voice-note transcription (Groq Whisper). If unset,
# audio inbound is described textually instead of transcribed (graceful degrade).
GROQ_API_KEY=

# Optional: registry-prefixed model id (default: anthropic:claude-sonnet-4-6).
# The Vercel AI SDK provider registry resolves the `<provider>:<id>` prefix.
# Examples: anthropic:claude-haiku-4-5, openai:gpt-4o-mini.
SHOWCASE_MODEL=anthropic:claude-sonnet-4-6

# Optional: max output tokens per reply (default: 1024).
MAX_TOKENS=1024

# Optional: port this server listens on (default: 4055).
# Point the transport package at it with CHAT_ENDPOINT_URL=http://localhost:4055
PORT=4055
